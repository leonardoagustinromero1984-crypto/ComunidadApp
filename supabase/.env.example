# Edge Function `push` — variables / secrets
# Copiá a supabase/.env SOLO para desarrollo local con Supabase CLI si aplica.
# En producción: Dashboard → Edge Functions → Secrets.
# Nunca commitees supabase/.env con valores reales.

# Proyecto Firebase (FCM HTTP v1)
FIREBASE_PROJECT_ID=tu-proyecto-firebase-ejemplo

# Cuenta de servicio (email)
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-ejemplo@tu-proyecto.iam.gserviceaccount.com

# Clave privada PKCS8; en secrets de dashboard suele ir con \n escapados
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nEJEMPLO_FICTICIO\n-----END PRIVATE KEY-----\n"

# URL y keys del proyecto Supabase para invocar la función en local (ficticios)
SUPABASE_URL=https://TU_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.EJEMPLO_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.EJEMPLO_SERVICE_ROLE_NO_USAR_EN_CLIENTE

# --- Edge Function `delete-account` ---
# Requiere SUPABASE_URL / SUPABASE_ANON_KEY / SUPABASE_SERVICE_ROLE_KEY.
# El cliente Android solo usa anon + JWT de usuario; nunca service_role.
