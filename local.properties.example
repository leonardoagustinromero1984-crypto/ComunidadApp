# Copiá este archivo como local.properties (está en .gitignore).
# Nunca commitees local.properties con valores reales.

# Ruta del Android SDK (ajustá tu usuario)
sdk.dir=C\:\\Users\\TU_USUARIO\\AppData\\Local\\Android\\Sdk

# ---------------------------------------------------------------------------
# Supabase — Project Settings → API
# Si falta URL o ANON_KEY, la app usa modo mock (sin crash).
# La UI y el código nuevo deben leer configuración vía AppConfigProvider
# (no BuildConfig / este archivo directamente). Ver ADR-0005.
#
# IMPORTANTE (APK localDebug en dispositivo físico):
# - No usar http://10.0.2.2 ni localhost: cleartext está deshabilitado y
#   10.0.2.2 solo existe en el emulador.
# - Preferí HTTPS remoto en SUPABASE_URL, o dejá staging configurado:
#   el flavor `local` hace fallback automático a SUPABASE_STAGING_* cuando
#   SUPABASE_URL es local/emulador/http.
# ---------------------------------------------------------------------------

# URL del proyecto remoto (HTTPS). Ejemplo ficticio:
SUPABASE_URL=https://TU_PROJECT_REF.supabase.co

# Clave anon/public (placeholder ficticio; no uses credenciales privilegiadas aquí)
# Nunca loguear esta clave. No va a AppConfig.
SUPABASE_ANON_KEY=<LOCAL_ANON_KEY>

# ---------------------------------------------------------------------------
# Solo emulador + Supabase CLI local (NO para APK físico sin adb reverse)
# Ejemplo (ficticio). El flavor local IGNORA este host y usa staging si está.
# SUPABASE_URL=http://10.0.2.2:55321
# SUPABASE_ANON_KEY=<anon_from_supabase_status_env>
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# STAGING (HTTPS remoto). Usado también como fallback de localDebug.
# Nunca localhost, 127.0.0.1 ni 10.0.2.2. Nunca service_role.
# ---------------------------------------------------------------------------
SUPABASE_STAGING_URL=https://<STAGING_PROJECT_REF>.supabase.co
SUPABASE_STAGING_PUBLISHABLE_KEY=<STAGING_PUBLISHABLE_KEY>
# SUPABASE_STAGING_ANON_KEY=<STAGING_ANON_KEY>

# ---------------------------------------------------------------------------
# PRODUCTION futura (placeholders ficticios; no habilita despliegue)
# ---------------------------------------------------------------------------
SUPABASE_PRODUCTION_URL=https://<PRODUCTION_PROJECT_REF>.supabase.co
SUPABASE_PRODUCTION_PUBLISHABLE_KEY=<PRODUCTION_PUBLISHABLE_KEY>
# SUPABASE_PRODUCTION_ANON_KEY=<PRODUCTION_ANON_KEY>

# Secrets de Edge Functions (FCM push) NO van en este archivo.
# Ver: supabase/.env.example y docs/leover-push-fcm-setup.md
